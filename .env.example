# ============================
# Database
# ============================
# Postgres (Neon recommended for free hosted): postgres://user:pass@host/db
# For local dev you can also run docker postgres or use a local file.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hara_ceylon?schema=public"

# ============================
# Auth.js (NextAuth v5)
# ============================
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Optional: Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# First admin account (seeded by prisma/seed.ts)
ADMIN_EMAIL="admin@haraceylon.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Hara Ceylon Admin"

# ============================
# PayHere Payment Gateway
# ============================
# Get these from your PayHere merchant account
# Sandbox: https://sandbox.payhere.lk/
# Production: https://www.payhere.lk/
PAYHERE_MERCHANT_ID=""
PAYHERE_MERCHANT_SECRET=""
# "sandbox" while testing, "live" for production
PAYHERE_MODE="sandbox"
# Public URL of this site (used for return_url, cancel_url, notify_url)
# In dev use ngrok so PayHere can reach your IPN webhook
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============================
# Email (Resend)
# ============================
RESEND_API_KEY=""
RESEND_FROM="Hara Ceylon <orders@haraceylon.com>"

# ============================
# Image Uploads (UploadThing)
# ============================
UPLOADTHING_TOKEN=""

# ============================
# Site Info
# ============================
NEXT_PUBLIC_SITE_NAME="Hara Ceylon"
NEXT_PUBLIC_CONTACT_EMAIL="info@haraceylon.com"
NEXT_PUBLIC_CONTACT_PHONE="+44 7438 413454"
